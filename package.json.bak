{
  "name": "whisky-core",
  "version": "0.0.0",
  "description": "(De)serialization functions for the Cardano blockchain along with related utility functions",
  "scripts": {
    "core:build-nodejs": "(rimraf ./packages/whisky-core/pkg && cd packages/whisky-core; WASM_BINDGEN_WEAKREF=1 wasm-pack build --target=nodejs; cd ../..; npm run js:ts-json-gen; cd packages/whisky-core; wasm-pack pack) && npm run js:flowgen",
    "core:build-browser": "(rimraf ./packages/whisky-core/pkg && cd packages/whisky-core; WASM_BINDGEN_WEAKREF=1 wasm-pack build --target=browser; cd ../..; npm run js:ts-json-gen; cd packages/whisky-core; wasm-pack pack) && npm run js:flowgen",
    "core:build-web": "(rimraf ./packages/whisky-core/pkg && cd packages/whisky-core; WASM_BINDGEN_WEAKREF=1 wasm-pack build --target=web; cd ../..; npm run js:ts-json-gen; cd packages/whisky-core; wasm-pack pack) && npm run js:flowgen",
    "core:build-asm": "(rimraf ./packages/whisky-core/pkg && cd packages/whisky-core; WASM_BINDGEN_WEAKREF=1 wasm-pack build --target=browser; cd ../..; npm run js:ts-json-gen; cd packages/whisky-core; wasm-pack pack) && npm run asm:build && npm run js:flowgen",
    "rust:publish": "cd packages/whisky && cargo publish && cd ../",
    "asm:build": "./binaryen/bin/wasm2js ./packages/whisky-core/pkg/whisky_core_bg.wasm --output ./packages/whisky-core/pkg/whisky_core.asm.js && node ./scripts/wasm-to-asm && node ./scripts/fix-buffer-ref.js",
    "core:check-warnings": "(cd packages/whisky-core; RUSTFLAGS=\"-D warnings\" cargo +stable build)",
    "core:test": "(cd packages/whisky-core; cargo test)",
    "rust:test": "(cd packages/whisky; cargo test)",
    "js:flowgen": "flowgen ./packages/whisky-core/pkg/whisky_core.d.ts -o ./packages/whisky-core/pkg/whisky_core.js.flow --add-flow-header",
    "js:prepublish": "npm run core:test && rimraf ./publish && cp -r ./packages/whisky-core/pkg ./publish && cp README.md publish/ && cp LICENSE publish/",
    "js:publish-nodejs": "npm run core:build-nodejs && npm run js:prepublish && node ./scripts/publish-helper -nodejs && cd publish && npm publish --access public",
    "js:publish-browser": "npm run core:build-browser && npm run js:prepublish && node ./scripts/publish-helper -browser && cd publish && npm publish --access public",
    "js:publish-asm": "npm run core:build-asm && npm run js:prepublish && node ./scripts/publish-helper -asmjs && cd publish && npm publish --access public",
    "js:ts-json-gen": "cd packages/whisky-core/json-gen && cargo +stable run && cd ../../.. && node ./scripts/run-json2ts.js && node ./scripts/json-ts-types.js",
    "rust:doc-clear": "rm -rf ./docs && mkdir docs && echo '<meta http-equiv=\"refresh\" content=\"0; url=whisky\">' > docs/index.html",
    "rust:doc": "npm run rust:doc-clear && RUSTDOCFLAGS=\"--cfg docsrs\" cargo doc --workspace --manifest-path packages/Cargo.toml --no-deps && cp -r ./packages/target/doc/* ./docs",
    "start-doc": "npm run rust:doc && npx http-server ./docs",
    "sh:bump-version": "./scripts/bump-version.sh",
    "sh:run-example": "./scripts/run-example.sh"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run core:test && npm run rust:test"
    }
  },
  "author": "SIDAN Lab",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidan-lab/whisky.git"
  },
  "devDependencies": {
    "flowgen": "1.21.0",
    "husky": "4.2.5",
    "json-schema-to-typescript": "^10.1.5",
    "rimraf": "3.0.2"
  }
}